# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Para desarrollo local (supabase start):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<key from supabase start>
# SUPABASE_SERVICE_ROLE_KEY=<key from supabase start>

# Para producción/staging (Supabase Cloud):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# STRIPE CONFIGURATION
# ============================================
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# APP URLS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000

# ============================================
# EMAIL SERVICE (Resend)
# ============================================
RESEND_API_KEY=re_your_api_key

# ============================================
# OPTIONAL: OpenAI for Supabase Studio AI
# ============================================
# OPENAI_API_KEY=sk-your-openai-key

# ============================================
# BOOKFAST AI (asistente)
# ============================================
# Proveedor principal del LLM. Valores válidos:
#   mistral    → Mistral (francesa, datos en UE) - por defecto
#   anthropic  → Claude (mejor tool use + prompt caching)
# Se puede cambiar sin tocar código, solo reiniciando el deploy.
ASISTENTE_LLM_PROVIDER=mistral

# Modelo a usar (según proveedor).
# Mistral: mistral-large-latest | mistral-small-latest | open-mistral-nemo
# Anthropic: claude-sonnet-4-6 | claude-haiku-4-5
ASISTENTE_LLM_MODEL=mistral-large-latest

# Claves de API de los proveedores (al menos la del proveedor activo).
# Se obtienen en:
#   Mistral: https://console.mistral.ai
#   Anthropic: https://console.anthropic.com
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# PWA / SERVICE WORKER
# ============================================
# Enabled automatically in production. Set to "false" to disable.
# NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false
